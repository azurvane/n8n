      "id": "81fce8f9-4128-4269-972d-364117b2deca",
      "name": "Fetch Ad Snapshots",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        912,
        80
      ],
      "credentials": {
        "postgres": {
          "id": "NZhIIAZ94aposWs7",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const competitors = $('Filter Active Competitors').all().map(i => i.json);\nconst snapshots = $input.all().map(i => i.json);\n\nconst grouped = {};\nfor (const s of snapshots) (grouped[s.competitor_id] = grouped[s.competitor_id] || []).push(s);\n\nconst results = [];\nfor (const c of competitors) {\n  const rows = grouped[c.competitor_id] || [];\n  if (rows.length === 0) {\n    results.push({ competitor_id: c.competitor_id, competitor_name: c.competitor_name, failed: true, reason: 'no ad snapshots found', ad_count: 0 });\n    continue;\n  }\n  const avgDays = rows.reduce((sum, r) => sum + (r.days_running || 0), 0) / rows.length;\n  const topAd = rows.reduce((a, b) => (b.days_running || 0) > (a.days_running || 0) ? b : a);\n  results.push({\n    competitor_id: c.competitor_id,\n    competitor_name: c.competitor_name,\n    failed: false,\n    ad_count: rows.length,\n    avg_days_running: Math.round(avgDays * 10) / 10,\n    top_ad_headline: topAd.ad_headline,\n    top_ad_days_running: topAd.days_running\n  });\n}\n\nreturn [{ json: { results } }];"
      },
      "id": "32a441b6-c52c-46e6-a18c-359a9f15db17",
      "name": "Compute Metrics Per Competitor",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        80
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer REPLACE_WITH_OPENROUTER_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: \"openai/gpt-4o-mini\", messages: [ { role: \"system\", content: \"You are a marketing analyst. Given competitor Facebook ad metrics as JSON, write a concise 3-4 sentence summary of patterns: which competitors run the most persistent (evergreen) ads, and any notable themes. Be factual, no fluff.\" }, { role: \"user\", content: JSON.stringify($json.results) } ] } }}",
        "options": {}
      },
      "id": "38abe181-e1ff-4090-bc4d-914a80cc75d3",
      "name": "Generate Pattern Summary (OpenRouter)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1344,
        80
      ],
      "credentials": {
        "openAiApi": {
          "id": "1NsBGROuTKjfk6jZ",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const summary = ($json.choices && $json.choices[0] && $json.choices[0].message.content || 'Summary unavailable.').trim();\nconst results = $('Compute Metrics Per Competitor').item.json.results;\nconst ok = results.filter(r => !r.failed);\nconst failed = results.filter(r => r.failed);\n\nconst lines = ok.map(r => `\\u2022 *${r.competitor_name}* \\u2014 ${r.ad_count} ads, avg ${r.avg_days_running}d running, top: \"${r.top_ad_headline}\" (${r.top_ad_days_running}d)`);\nconst failedLines = failed.map(r => `\\u2022 *${r.competitor_name}* \\u2014 FAILED: ${r.reason}`);\n\nconst date = new Date().toISOString().slice(0, 10);\nlet digest = `*Facebook Ads Spy Daily Digest \\u2014 ${date}*\\n\\n${summary}\\n\\n*Competitor Breakdown:*\\n${lines.join('\\n')}`;\nif (failed.length) digest += `\\n\\n*Failed / No Data:*\\n${failedLines.join('\\n')}`;\n\nreturn [{ json: { digest_text: digest, ok_count: ok.length, failed_count: failed.length, run_date: date } }];"
      },
      "id": "9ce699bd-dbbc-4ce4-b596-e36c3630d9a1",
