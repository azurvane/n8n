      "id": "98c160d4-e9ba-4a4b-b585-4ae5c353fd6a",
      "name": "Collect Competitor IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        80
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM srp1004.ad_snapshots WHERE competitor_id = ANY($1);",
        "options": {
