    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst groups = {};\n\nfor (const item of items) {\n  const key = item.json.normalized_url;\n  if (!groups[key]) groups[key] = [];\n  groups[key].push(item.json);\n}\n\nconst output = [];\n\nfor (const key of Object.keys(groups)) {\n  const group = groups[key].sort((a, b) => a.record_id - b.record_id);\n  const primary = group[0];\n  const others = group.slice(1);\n\n  const mergedFields = ['full_name', 'email', 'phone', 'source'];\n  const merged = { ...primary };\n  for (const field of mergedFields) {\n    if (merged[field] === null || merged[field] === undefined || merged[field] === '') {\n      const fallback = others.find(o => o[field] !== null && o[field] !== undefined && o[field] !== '');\n      if (fallback) merged[field] = fallback[field];\n    }\n  }\n\n  output.push({\n    json: {\n      record_id: primary.record_id,\n      normalized_url: key,\n      status: 'crm_ready',\n      merged_into: null,\n      full_name: merged.full_name,\n      email: merged.email,\n      phone: merged.phone,\n      source: merged.source\n    }\n  });\n\n  for (const loser of others) {\n    output.push({\n      json: {\n        record_id: loser.record_id,\n        normalized_url: key,\n        status: 'merged',\n        merged_into: primary.record_id,\n        full_name: loser.full_name,\n        email: loser.email,\n        phone: loser.phone,\n        source: loser.source\n      }\n    });\n  }\n}\n\nreturn output;"
      },
