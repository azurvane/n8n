      "parameters": {
        "jsCode": "const items = $input.all();\nconst counts = {};\n\nfor (const item of items) {\n  const key = item.json.normalized_url;\n  counts[key] = (counts[key] || 0) + 1;\n}\n\nreturn items.map(item => ({\n  json: {\n    ...item.json,\n    is_duplicate: counts[item.json.normalized_url] > 1\n  }\n}));"
      },
