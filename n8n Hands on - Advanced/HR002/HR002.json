    {
      "parameters": {
        "jsCode": "function normalizeLinkedInUrl(raw) {\n  if (!raw || typeof raw !== 'string') return null;\n  let url = raw.trim().toLowerCase();\n  url = url.replace(/^https?:\\/\\//, '');\n  url = url.replace(/^www\\./, '');\n  if (!url.startsWith('linkedin.com/')) return null;\n  url = url.split('?')[0].split('#')[0];\n  url = url.replace(/\\/+$/, '');\n  const match = /^linkedin\\.com\\/in\\/([a-z0-9\\-_%]+)$/.exec(url);\n  if (!match) return null;\n  return `linkedin.com/in/${match[1]}`;\n}\n\nconst items = $input.all();\n\nreturn items\n  .map(item => {\n    const normalized = normalizeLinkedInUrl(item.json.linkedin_url);\n    return { json: { ...item.json, normalized_url: normalized } };\n  })\n  .filter(item => item.json.normalized_url !== null);"
      },
      "id": "aba41f97-01e2-44d7-ac39-e5ba3b3acb2f",
