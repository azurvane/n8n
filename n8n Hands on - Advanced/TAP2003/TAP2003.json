    {
      "parameters": {
        "jsCode": "const posts = $input.all().map(i => i.json);\nconst lines = posts.map((p, idx) => `Post ${idx + 1}:\\nURL: ${p.linkedinUrl || 'unknown'}\\nAuthor: ${(p.author && p.author.name) || 'unknown'}\\nContent: ${(p.content || '').slice(0, 600)}\\nLikes: ${(p.engagement && p.engagement.likes) ?? 'n/a'} Comments: ${(p.engagement && p.engagement.comments) ?? 'n/a'}`).join('\\n\\n');\n\nconst prompt = `You are analyzing a batch of competitor LinkedIn posts. For each post, extract fixed fields. Respond ONLY in this exact Markdown format, nothing else:\n\n## Executive Summary\n<2-3 sentence summary of overall themes and competitive signals across all posts>\n\n## Posts\n### Post 1\n- URL: <url>\n- Author: <author>\n- Topic: <short topic label>\n- Sentiment: <Positive|Neutral|Negative>\n- Engagement Level: <High|Medium|Low>\n- Key Takeaway: <one sentence>\n\n(repeat ### Post N for every post, in order)\n\nHere are the posts:\\n\\n${lines}`;\n\nreturn [{ json: { prompt, post_count: posts.length } }];"
      },
      "id": "9cbb6b96-c088-4eca-b3cd-c9f27364c24b",
      "name": "Build GPT Batch Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -432,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.text || '';\nconst postsSection = raw.split(/##\\s*Posts/i)[1] || '';\nconst blocks = postsSection.split(/###\\s*Post\\s*\\d+/i).slice(1);\n\nconst rows = [];\nfor (const block of blocks) {\n  const get = (label) => {\n    const m = new RegExp(`-\\\\s*${label}\\\\s*:\\\\s*(.+)`, 'i').exec(block);\n    return m ? m[1].trim() : null;\n  };\n  const row = {\n    url: get('URL'),\n    author: get('Author'),\n    topic: get('Topic'),\n    sentiment: get('Sentiment'),\n    engagement_level: get('Engagement Level'),\n    key_takeaway: get('Key Takeaway')\n  };\n  const complete = Object.values(row).every(v => v && v.length > 0);\n  if (complete) {\n    rows.push({ json: { timestamp: new Date().toISOString(), status: 'ok', ...row } });\n  }\n}\n\nreturn rows;"
      },
