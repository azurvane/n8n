    {
      "parameters": {
        "jsCode": "const raw = $json.text || '';\nconst summaryMatch = /##\\s*Executive Summary\\s*([\\s\\S]*?)##\\s*Posts/i.exec(raw);\nconst summary = summaryMatch ? summaryMatch[1].trim() : 'Summary unavailable.';\n\nconst postsSection = raw.split(/##\\s*Posts/i)[1] || '';\nconst totalBlocks = (postsSection.match(/###\\s*Post\\s*\\d+/gi) || []).length;\nconst blocks = postsSection.split(/###\\s*Post\\s*\\d+/i).slice(1);\nconst requiredLabels = ['URL', 'Author', 'Topic', 'Sentiment', 'Engagement Level', 'Key Takeaway'];\nconst validCount = blocks.filter(b => requiredLabels.every(l => new RegExp(`-\\\\s*${l}\\\\s*:\\\\s*(.+)`, 'i').test(b))).length;\n\nreturn [{ json: {\n  timestamp: new Date().toISOString(),\n  executive_summary: summary,\n  total_posts: totalBlocks,\n  rows_written: validCount,\n  rows_skipped: totalBlocks - validCount\n} }];"
      },
