        "jsCode": "const target = $('Loop One Competitor').item.json;\nconst rows = $input.all().map(i => i.json);\nconst profile = rows[0] || {};\n\nreturn [{ json: {\n  timestamp: new Date().toISOString(),\n  competitor_id: target.competitor_id,\n  competitor_name: target.competitor_name,\n  instagram_handle: target.instagram_handle,\n  followers: profile.followersCount ?? null,\n  following: profile.followsCount ?? null,\n  posts_count: profile.postsCount ?? null,\n  bio: profile.biography ?? null,\n  external_url: profile.externalUrl ?? null,\n  email_found: (profile.biography && (profile.biography.match(/[\\w.+-]+@[\\w-]+\\.[\\w.-]+/) || [null])[0]) || null,\n  status: rows.length ? 'ok' : 'no_data'\n} }];"
