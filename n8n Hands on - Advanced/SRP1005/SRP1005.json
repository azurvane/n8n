    {
      "parameters": {
        "jsCode": "const target = $('Loop One Competitor').item.json;\nconst rows = Array.isArray($json) ? $json : ($json.items || []);\nconst text = rows.map(r => r.text || '').join(' ');\n\nconst emails = [...new Set((text.match(/[\\w.+-]+@[\\w-]+\\.[\\w.-]+/g) || []))];\nconst prices = [...new Set((text.match(/[$\\u20b9]\\s?\\d[\\d,]*(\\.\\d+)?/g) || []))];\nconst certKeywords = ['ISO', 'certified', 'certification', 'GMP', 'FDA approved', 'organic certified'];\nconst certs = certKeywords.filter(k => text.toLowerCase().includes(k.toLowerCase()));\n\nreturn [{ json: {\n  timestamp: new Date().toISOString(),\n  competitor_id: target.competitor_id,\n  competitor_name: target.competitor_name,\n  website_url: target.website_url,\n  reachable: true,\n  emails_found: emails.join(', ') || null,\n  prices_found: prices.join(', ') || null,\n  certifications_found: certs.join(', ') || null,\n  raw_snippet: text.slice(0, 300)\n} }];"
      },
