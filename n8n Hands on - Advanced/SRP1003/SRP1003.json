    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst groups = {};\nfor (const item of items) {\n  const key = item.json.normalized_url;\n  (groups[key] = groups[key] || []).push(item.json);\n}\n\nconst output = [];\nconst fields = ['username', 'profile_url', 'followers', 'category'];\n\nfor (const key of Object.keys(groups)) {\n  const group = groups[key].sort((a, b) => a.record_id - b.record_id);\n  const primary = group[0];\n  const others = group.slice(1);\n  const merged = { ...primary };\n\n  for (const f of fields) {\n    if (merged[f] === null || merged[f] === undefined || merged[f] === '') {\n      const fallback = others.find(o => o[f] !== null && o[f] !== undefined && o[f] !== '');\n      if (fallback) merged[f] = fallback[f];\n    }\n  }\n\n  output.push({ json: { record_id: primary.record_id, normalized_url: key, status: 'crm_ready', merged_into: null, username: merged.username, profile_url: merged.profile_url, followers: merged.followers, category: merged.category } });\n\n  for (const loser of others) {\n    output.push({ json: { record_id: loser.record_id, normalized_url: key, status: 'merged', merged_into: primary.record_id, username: loser.username, profile_url: loser.profile_url, followers: loser.followers, category: loser.category } });\n  }\n}\n\nreturn output;"
      },
