    {
      "parameters": {
        "jsCode": "function normalize(raw) {\n  if (!raw || typeof raw !== 'string') return null;\n  let url = raw.trim().toLowerCase();\n  url = url.replace(/^https?:\\/\\//, '');\n  url = url.replace(/^(www\\.|m\\.)/, '');\n  if (!url.startsWith('instagram.com/')) return null;\n  let rest = url.slice('instagram.com/'.length).split('?')[0].split('#')[0].replace(/\\/+$/, '');\n  const match = /^([a-z0-9._]+)$/.exec(rest);\n  if (!match) return null;\n  return `instagram.com/${match[1]}`;\n}\n\nreturn $input.all()\n  .map(item => ({ json: { ...item.json, normalized_url: normalize(item.json.profile_url) } }))\n  .filter(item => item.json.normalized_url !== null);"
      },
