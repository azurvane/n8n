    {
      "parameters": {
        "jsCode": "// 1. Extract the main data object for cleaner access\nconst itemData = $input.item.json || {};\n\n// 2. Determine company enrichment status\nconst companyName = itemData.company?.name || 'N/A';\nconst enrichmentStatus = itemData.company?.name ? 'enriched' : 'enrichment_failed';\n\n// 3. Determine the name based on the duplicate flag logic\nlet finalName = null;\nif (itemData.is_duplicate !== undefined) {\n  finalName = itemData.name || null;\n}\n\n// 4. Return the structured payload\nreturn [{\n  json: {\n    candidate_id: itemData.candidate_id || null,\n    name: finalName,\n    email: itemData.email || null,\n    linkedin: itemData.linkedin || null,\n    run_id: itemData.run_id || null,\n    enrichment_status: enrichmentStatus,\n    enriched_company: companyName\n  }\n}];"
      },
