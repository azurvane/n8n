      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\nif (!staticData.processedIds) {\n  staticData.processedIds = {};\n}\n\nconst candidateId = String($input.item.json.candidate_id).trim();\nconst isDuplicate = staticData.processedIds[candidateId] === true;\n\n// Reserve the slot immediately so same-run duplicates are also caught\nif (!isDuplicate) {\n  staticData.processedIds[candidateId] = true;\n}\n\nreturn [{\n  json: {\n    ...$input.item.json,\n    is_duplicate: isDuplicate\n  }\n}];"
      },
