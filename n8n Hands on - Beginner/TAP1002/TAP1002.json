        "jsCode": "// Get the base item data\nconst itemData = $json;\n\n// 1. Extract base fields directly from the bottom metadata fields\nconst linkedin_url = itemData.linkedin_url || '';\nconst name = itemData.name || '';\nconst company = itemData.company || '';\nconst run_id = itemData.run_id || '';\nconst processed_at = itemData.processed_at || '';\n\n// Initialize fallback variables for fields hidden inside the search results\nlet email = itemData.email || ''; \nlet title = itemData.title || '';\nlet enriched_bio = '';\n\n// 2. Parse through organic search results to find missing details\nif (itemData.organic_results && Array.isArray(itemData.organic_results)) {\n  \n  // Try to find an email from RocketReach results if the source sheet was empty\n  if (!email) {\n    const rocketReachResult = itemData.organic_results.find(res => \n      res.link && res.link.includes('rocketreach.co') && res.snippet && res.snippet.includes('@')\n    );\n    if (rocketReachResult) {\n      // Regex pattern to extract hidden or clear text email patterns from snippet\n      const emailMatch = rocketReachResult.snippet.match(/([a-zA-Z0-9\\._\\*]+@[a-zA-Z0-9\\._\\-]+\\.[a-zA-Z0-9\\._\\-]+)/);\n      if (emailMatch) {\n        email = emailMatch[0];\n      }\n    }\n  }\n\n  // Find the most relevant LinkedIn profile match in the search index to extract actual Title\n  const linkedInResult = itemData.organic_results.find(res => \n    res.link && res.link.includes('linkedin.com/in/')\n  );\n  \n  if (linkedInResult) {\n    // Standardize title extraction from corporate search titles (e.g., \"Aditi Sharma - Software Engineer | Angular\")\n    if (linkedInResult.title) {\n      const titleParts = linkedInResult.title.split('-');\n      if (titleParts.length > 1) {\n        title = titleParts[1].split('|')[0].trim();\n      } else {\n        title = linkedInResult.title;\n      }\n    }\n    // Build a dynamic profile snapshot bio using the snippet text\n    enriched_bio = linkedInResult.snippet || '';\n  } else if (itemData.organic_results[0]) {\n    // Fallback bio: use the snippet of the absolute #1 search result ranking\n    enriched_bio = itemData.organic_results[0].snippet || '';\n  }\n}\n\n// Return the clean, linear object mapping exactly to your Clean Output Sheet headers\nreturn {\n  json: {\n    linkedin_url,\n    name,\n    email,\n    company,\n    title: title || itemData.title || 'Professional at ' + company,\n    enriched_bio,\n    run_id,\n    processed_at\n  }\n};"
      },
