    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// Initialise the store if it doesn't exist yet\nif (!staticData.processedKeys) {\n  staticData.processedKeys = {};\n}\n\n// Use linkedin_url as the unique key — normalise it so casing/trailing slashes don't matter\nconst recordKey = String($input.item.json.linkedin_url)\n  .trim()\n  .toLowerCase()\n  .replace(/\\/+$/, '');  // strip any trailing slashes\n\n// Check if we've seen this key before in any previous or current run\nconst isDuplicate = staticData.processedKeys[recordKey] !== undefined;\n\n// Reserve the slot immediately so parallel/fast items can't both slip through\nif (!isDuplicate) {\n  staticData.processedKeys[recordKey] = {\n    run_id:       $input.item.json.run_id,\n    name:         $input.item.json.name,\n    reserved_at:  new Date().toISOString()\n  };\n}\n\n// Pass everything forward, just add the duplicate flag\nreturn [{\n  json: {\n    ...$input.item.json,\n    duplicate: isDuplicate\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
