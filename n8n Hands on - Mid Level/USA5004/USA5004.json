    {
      "parameters": {
        "jsCode": "// Acumatica Employee Sync - Duplicate Check\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.processedEmployees) staticData.processedEmployees = {};\n\nconst items = $input.all();\nconst output = [];\n\nfor (const item of items) {\n  const incoming = item.json;\n  const key = String(incoming.employee_id || incoming.email).trim().toLowerCase();\n  let isDuplicate = false;\n  let finalRecord = { ...incoming };\n\n  if (staticData.processedEmployees[key]) {\n    isDuplicate = true;\n  } else {\n    staticData.processedEmployees[key] = finalRecord;\n  }\n\n  output.push({ json: { ...finalRecord, record_key: key, duplicate: isDuplicate } });\n}\nreturn output;"
      },
