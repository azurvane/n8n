      "id": "c1595b4f-8d36-4ae2-9066-ab676b898282",
      "name": "Sync to Acumatica"
    },
    {
      "parameters": {
        "jsCode": "// 1. Fetch all items from both target nodes by their exact names\nconst part1Items = $('Rate Limit Wait').all();\nconst part2Items = $('Sync to Acumatica').all();\n\n// 2. Create a fast lookup map for the HTTP responses based on the email\nconst httpLookup = {};\nfor (const item of part2Items) {\n  const json = item.json;\n  if (json.received_email) {\n    const emailKey = String(json.received_email).trim().toLowerCase();\n    httpLookup[emailKey] = json;\n  }\n}\n\nconst output = [];\n\n// 3. Loop through your primary employee records and merge data\nfor (const item of part1Items) {\n  const employee = item.json;\n  \n  if (!employee.email) {\n    // If no email exists to match against, push the record as-is\n    output.push({ json: employee });\n    continue;\n  }\n\n  const emailKey = String(employee.email).trim().toLowerCase();\n  const matchedHttpData = httpLookup[emailKey];\n\n  if (matchedHttpData) {\n    // Merge the records and map the second part's fields cleanly\n    output.push({\n      json: {\n        ...employee,\n        acumatica_id: matchedHttpData.id,\n        sync_status: matchedHttpData.sync_status\n      }\n    });\n  } else {\n    // Keep the employee record even if the HTTP node didn't have sync details\n    output.push({\n      json: {\n        ...employee,\n        acumatica_id: null,\n        sync_status: \"not_found\"\n      }\n    });\n  }\n}\n\nreturn output;"
      },
