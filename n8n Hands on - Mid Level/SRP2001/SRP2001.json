      "id": "0e12e42f-ab4d-4e4c-8426-fd8729df8857",
      "name": "Quality filter"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\n\n// 1. Fetch the original data from the \"Wait\" node for this specific item index\nconst waitNodeData = $(\"Wait\").item.json;\n\n// Safe access to first organic result\nconst result = (item.organic_results && item.organic_results[0]) || {};\n\nconst enriched_title = result.title ?? null;\nconst enriched_link = result.link ?? null;\nconst enriched_snippet = result.snippet ?? null;\nconst enrichment_status = result.title ? \"Success\" : \"No Result\";\n\n// Parse revenue string like \"$5M\", \"$12M\", \"Unknown\" -> numeric\nfunction parseRevenue(raw) {\n  if (!raw || typeof raw !== \"string\") return null;\n  const cleaned = raw.replace(/[$,]/g, \"\").trim().toUpperCase();\n  if (cleaned === \"UNKNOWN\") return null;\n  const match = cleaned.match(/^([\\d.]+)([MK B]?)$/);\n  if (!match) return null;\n  const num = parseFloat(match[1]);\n  const unit = match[2];\n  if (unit === \"M\") return num * 1_000_000;\n  if (unit === \"K\") return num * 1_000;\n  if (unit === \"B\") return num * 1_000_000_000;\n  return num;\n}\n\nconst revenueNum = parseRevenue(item.estimated_revenue || waitNodeData.estimated_revenue);\n\n// Revenue tier\nlet revenue_tier;\nif (revenueNum === null) {\n  revenue_tier = \"Tier 3\";\n} else if (revenueNum >= 10_000_000) {\n  revenue_tier = \"Tier 1\";\n} else if (revenueNum >= 5_000_000) {\n  revenue_tier = \"Tier 2\";\n} else {\n  revenue_tier = \"Tier 3\";\n}\n\n// Threat level heuristic\nlet threat_level;\nif (revenue_tier === \"Tier 1\") {\n  threat_level = \"High\";\n} else if (revenue_tier === \"Tier 2\") {\n  threat_level = \"Medium\";\n} else {\n  threat_level = \"Low\";\n}\n\nreturn {\n  json: {\n    // 2. Spread all incoming fields from the Wait node first\n    ...waitNodeData,\n    \n    // 3. Add or overwrite fields with the enrichment results\n    competitor_id: item.id || waitNodeData.id,\n    normalized_domain: item.normalized_domain || waitNodeData.normalized_domain,\n    clean_company_name: item.clean_company_name || waitNodeData.raw_company_name,\n    market_category: item.market_category || waitNodeData.market_category,\n    revenue_tier,\n    threat_level,\n    last_enriched: new Date().toISOString(),\n    enriched_title,\n    enriched_link,\n    enriched_snippet,\n    enrichment_status\n  }\n};"
      },
