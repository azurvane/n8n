      "id": "d00eeb24-7aee-48f5-943f-9c792d4e096d",
      "name": "Validate input"
    },
    {
      "parameters": {
        "jsCode": "// 1. Get the global static data storage\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.processedRecords) {\n  staticData.processedRecords = {};\n}\n\n// 2. Get ALL incoming items from the node\nconst items = $input.all();\nconst output = [];\n\n// 3. Loop through every single item in the input array\nfor (const item of items) {\n  const incoming = item.json;\n  \n  // Check for website_url instead of instagram_handle\n  if (!incoming.website_url) {\n    output.push({ json: { ...incoming, duplicate: false } });\n    continue;\n  }\n\n  // Normalize the URL for basic casing and spacing consistency\n  const key = String(incoming.website_url).trim().toLowerCase();\n  let isDuplicate = false;\n  let finalRecord = { ...incoming };\n\n  if (staticData.processedRecords[key] !== undefined) {\n    isDuplicate = true;\n    const existing = staticData.processedRecords[key];\n\n    // Merge logic for payload keys\n    const mergeFields = ['row_number', 'id', 'raw_company_name', 'website_url', 'market_category', 'estimated_revenue', 'status', 'run_id', 'record_key'];\n    for (const field of mergeFields) {\n      if ((finalRecord[field] === undefined || finalRecord[field] === '') && existing[field]) {\n        finalRecord[field] = existing[field];\n      }\n    }\n    // Update the static storage with the merged record\n    staticData.processedRecords[key] = finalRecord;\n  } else {\n    // First time seeing this website URL, save it to storage\n    staticData.processedRecords[key] = finalRecord;\n  }\n\n  // 4. Push the result into our output array\n  output.push({\n    json: {\n      ...finalRecord,\n      duplicate: isDuplicate\n    }\n  });\n}\n\n// 5. Return all processed items back to n8n\nreturn output;"
      },
