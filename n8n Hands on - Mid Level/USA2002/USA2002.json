    },
    {
      "parameters": {
        "jsCode": "// === Duplicate Detection + Merger ===\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.masterRecords) staticData.masterRecords = {};\n\nconst items = $input.all();\nconst output = [];\n\nfor (const item of items) {\n  const rec = item.json;\n  const key = String(rec.profile_url || rec.email || rec.record_id).trim().toLowerCase().replace(/\\//g, '');\n\n  let isDuplicate = false;\n  let masterRecord = rec;\n\n  if (staticData.masterRecords[key]) {\n    isDuplicate = true;\n    const existing = staticData.masterRecords[key];\n    // Merge: Prefer non-empty values from either record\n    masterRecord = {\n      ...existing,\n      full_name: existing.full_name || rec.full_name,\n      email: existing.email || rec.email,\n      company: existing.company || rec.company,\n      profile_url: existing.profile_url || rec.profile_url\n    };\n  } else {\n    staticData.masterRecords[key] = masterRecord;\n  }\n\n  output.push({\n    json: {\n      ...masterRecord,\n      run_id: rec.run_id,\n      record_key: key,\n      is_duplicate: isDuplicate,\n      master_record_id: isDuplicate ? staticData.masterRecords[key].record_id : rec.record_id\n    }\n  });\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
