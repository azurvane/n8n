      "id": "c898465b-7ae5-4e0e-bc18-c16ada64c2b0",
      "name": "Detect & Merge Duplicates"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE usa2002.records SET status = CASE WHEN '{{ $json.is_duplicate }}' = 'true' THEN 'merged' ELSE 'processed' END, master_record_id = '{{ $json.master_record_id }}' WHERE record_id = '{{ $json.record_id }}';",
        "options": {}
