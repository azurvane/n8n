    {
      "parameters": {
        "jsCode": "// 1. Get global static data storage\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.processedKeys) {\n  staticData.processedKeys = {};\n}\n\nconst items = $input.all();\nconst output = [];\n\n// 2. Loop through every incoming item\nfor (const item of items) {\n  const incoming = item.json;\n\n  // If no email, can't dedupe on it — pass through, not flagged\n  if (!incoming.email) {\n    output.push({ json: { ...incoming, duplicate: false } });\n    continue;\n  }\n\n  // Normalize key\n  const key = String(incoming.email).trim().toLowerCase();\n  let isDuplicate = false;\n\n  if (staticData.processedKeys[key] !== undefined) {\n    // Already seen this email — within this run or a previous run\n    isDuplicate = true;\n  } else {\n    // Reserve the slot immediately (handles same-batch duplicates too)\n    staticData.processedKeys[key] = {\n      learner_id: incoming.learner_id,\n      row_id: incoming.row_id,\n      processed_at: new Date().toISOString()\n    };\n  }\n\n  output.push({\n    json: {\n      ...incoming,\n      record_key: key,\n      duplicate: isDuplicate\n    }\n  });\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
