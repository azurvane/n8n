    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst output = [];\n\nconst runId = $now.toFormat('yyyyMMdd-HHmmss') + '-' + Math.random().toString(36).substring(2, 8);\n\nfor (const item of items) {\n  const d = item.json;\n\n  // Two-step title cleaning pattern\n  let cleanName = (d.full_name || '').toString().trim();\n  cleanName = cleanName.replace(/\\s+/g, ' ');\n\n  output.push({\n    json: {\n      opportunity_id: 'OPP-' + (d.learner_id || 'UNK').toString().replace(/[^a-zA-Z0-9]/g, ''),\n      full_name: $input.first().json.full_name,\n      learner_id: d.learner_id,\n      opportunity_name: cleanName + ' - ' + (d.course_interest || 'General Interest'),\n      contact_email: (d.email || '').toString().trim().toLowerCase(),\n      contact_phone: d.phone || null,\n      stage: 'New',\n      source: d.lead_source || 'Unknown',\n      run_id: runId,\n      record_key: d.record_key,\n      row_id: d.row_id, // carried through so we can update raw_learners status later\n      created_at: new Date().toISOString(),\n      updated_at: new Date().toISOString()\n    }\n  });\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
