        "query": "INSERT INTO tap1005.opportunity (\n    opportunity_id, learner_id, opportunity_name, contact_email, \n    contact_phone, stage, source, run_id, record_key, created_at, updated_at    \n)\nVALUES (\n    '{{ $json.opportunity_id }}', -- Or handle via a UUID generation if it's new\n    '{{ $json.learner_id }}',\n    '{{ $json.full_name }}',      -- Maps to opportunity_name\n    '{{ $json.contact_email }}',\n    '{{ $json.contact_phone }}',\n    'Applied',                    -- Default stage string\n    '{{ $json.source }}',\n    '{{ $json.run_id }}',\n    '{{ $json.record_key }}',\n    NOW(),                        -- PostgreSQL timestamp functions work natively\n    NOW()\n);",
