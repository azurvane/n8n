      "id": "03d54f42-bee2-44df-abcb-b9a45a34f311",
      "name": "Validate input"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nif (!staticData.processedRecords) {\n  staticData.processedRecords = {};\n}\n\nconst incoming = $input.item.json;\nconst key = String(incoming.record_key).trim().toLowerCase();\n\nlet isDuplicate = false;\nlet finalRecord = { ...incoming };\n\nif (staticData.processedRecords[key] !== undefined) {\n  isDuplicate = true;\n  const existing = staticData.processedRecords[key];\n\n  // merge: keep existing value unless incoming has a non-empty value for that field\n  const mergeFields = ['name', 'company', 'instagram_handle', 'instagram_url', 'followers', 'bio'];\n  for (const field of mergeFields) {\n    if ((finalRecord[field] === undefined || finalRecord[field] === '') && existing[field]) {\n      finalRecord[field] = existing[field];\n    }\n  }\n  staticData.processedRecords[key] = finalRecord;\n} else {\n  staticData.processedRecords[key] = finalRecord;\n}\n\nreturn [{\n  json: {\n    ...finalRecord,\n    duplicate: isDuplicate\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
