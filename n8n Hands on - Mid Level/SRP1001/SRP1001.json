      "id": "74b5701d-b6b4-45b0-9dcb-2fe2c015671a",
      "name": "Quality filter"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\nconst result = (input.organic_results && input.organic_results[0]) || {};\n\n// extract instagram handle from the link, e.g. https://www.instagram.com/p/DDWeBnmP5wP/ -> won't give a handle (it's a post link)\n// so prefer the handle already known from source data, fall back to parsing \"source\" field e.g. \"Instagram · womenstabloid\"\nlet handle = $('Check duplicate').item.json.instagram_handle || '';\nhandle = String(handle).trim().toLowerCase().replace('@', '');\n\nif (!handle && result.source && result.source.includes('·')) {\n  handle = result.source.split('·')[1].trim().toLowerCase();\n}\n\nconst instagram_url = handle ? `https://instagram.com/${handle}` : (result.link || '');\n\nlet title = result.title || '';\n// Remove everything up to and including the first \"- \"\nif (title.includes('- ')) {\n  title = title.split('- ').slice(1).join('- ').trim();\n}\n// Remove \" at \" and everything after it\nif (title.toLowerCase().includes(' at ')) {\n  title = title.split(/\\s+[aA][tT]\\s+/)[0].trim();\n}\n\nconst bio = result.snippet || '';\nconst serp_link = result.link || '';\n\nreturn [{\n  json: {\n    run_id: $('Check duplicate').item.json.run_id,\n    record_key: $('Check duplicate').item.json.record_key,\n    name: $('Check duplicate').item.json.name,\n    company: $('Check duplicate').item.json.company,\n    instagram_handle: handle,\n    instagram_url: instagram_url,\n    serp_title: title,\n    serp_link: serp_link,\n    bio: bio,\n    status: 'success',\n    processed_at: $now.toISO()\n  }\n}];"
      },
