        "jsCode": "const item = $input.item.json;\nconst run_id = item.run_id;\nconst record_key = item.record_key;\nconst topic = item.Topic;\n\nlet parsed = item.output;\n\n// Fallback: If it's a string (e.g., if you swap models or remove the parser later)\nif (typeof parsed === 'string') {\n  let raw = parsed.trim().replace(/^```json/i, '').replace(/^```/, '').replace(/```$/, '').trim();\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    return [{\n      json: {\n        run_id,\n        record_key,\n        ai_valid: false,\n        error_reason: 'AI output was not valid JSON string'\n      }\n    }];\n  }\n}\n\n// Ensure it's treated as an array\nif (parsed && !Array.isArray(parsed)) {\n  parsed = [parsed];\n}\n\nif (!parsed || parsed.length === 0) {\n  return [{\n    json: { run_id, record_key, ai_valid: false, error_reason: 'AI returned empty array or invalid format' }\n  }];\n}\n\nconst required = ['title', 'rationale', 'category', 'priority', 'ice_score', 'owner_role', 'due_days'];\nconst output = [];\n\nfor (const rec of parsed) {\n  const missing = required.filter(f => rec[f] === undefined || rec[f] === '' || rec[f] === null);\n  if (missing.length > 0) {\n    output.push({\n      json: {\n        run_id,\n        record_key,\n        ai_valid: false,\n        error_reason: `Missing fields: ${missing.join(', ')}`\n      }\n    });\n    continue;\n  }\n\n  output.push({\n    json: {\n      run_id,\n      record_key,\n      ai_valid: true,\n      title: rec.title,\n      rationale: rec.rationale,\n      category: rec.category,\n      priority: rec.priority,\n      ice_score: rec.ice_score,\n      owner_role: rec.owner_role,\n      due_days: rec.due_days,\n      source_reference: rec.source_reference || topic\n    }\n  });\n}\n\nreturn output;"
      },
