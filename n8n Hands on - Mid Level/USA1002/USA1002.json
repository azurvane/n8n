    {
      "parameters": {
        "jsCode": "return $input.all().map((item, index) => {\n    const company = item.json;\n    \n    // 1. Process and format ONLY the requested fields from the API input\n    const extractedInfo = {\n        partner_name: company.name || \"\",\n        linkedin_url: company.linkedinUrl || \"\",\n        description: company.description || \"\",\n        employee_range: company.employeeCountRange ? `${company.employeeCountRange.start}-${company.employeeCountRange.end}` : \"\",\n        industry: company.industries?.[0]?.title || \"\"\n    };\n\n    // 2. Pull the required historical tracking keys from the \"Pacing Wait\" node\n    let pacingWaitData = {};\n    try {\n        pacingWaitData = $(\"Pacing Wait\").item.json;\n    } catch (error) {\n        pacingWaitData = {};\n    }\n\n    // 3. Return ONLY the wait node data combined with the processed fields\n    return {\n        json: {\n            ...pacingWaitData,\n            ...extractedInfo\n        }\n    };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
