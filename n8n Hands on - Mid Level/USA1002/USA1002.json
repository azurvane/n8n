    {
      "parameters": {
        "jsCode": "// Product Partner Companies Duplicate Check\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.processedPartners) staticData.processedPartners = {};\n\nconst items = $input.all();\nconst output = [];\n\nfor (const item of items) {\n  const inc = item.json;\n  if (!inc.website_url) {\n    output.push({json: {...inc, duplicate: false}});\n    continue;\n  }\n  const key = String(inc.website_url).trim().toLowerCase().replace(/\\//g,'');\n  let isDup = false;\n  if (staticData.processedPartners[key]) isDup = true;\n  else staticData.processedPartners[key] = inc;\n  output.push({json: {...inc, record_key: key, duplicate: isDup}});\n}\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3312,
        1200
      ],
