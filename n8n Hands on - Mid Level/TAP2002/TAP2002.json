    {
      "parameters": {
        "jsCode": "// Retrieve the input data\nconst items = $input.all();\n\nlet part1, part2;\n\n// Check if the input came in as a single item containing an array, or as two separate n8n items\nif (items.length === 1 && Array.isArray(items[0].json)) {\n  part1 = items[0].json[0];\n  part2 = items[0].json[1];\n} else if (items.length >= 2) {\n  part1 = items[0].json;\n  part2 = items[1].json;\n} else {\n  throw new Error(\"Unexpected input structure. Expected an array with at least two objects.\");\n}\n\n// Extract and map all available high-level metadata from Part 2\nconst mappedPart2 = {\n  profile_id: part2.id,\n  instagram_handle: part2.username,\n  profile_url: part2.url,\n  normalized_url: part2.inputUrl || part2.url,\n  full_name: part2.fullName,\n  bio_description: part2.biography,\n  followers_count: part2.followersCount,\n  following_count: part2.followsCount,\n  post_count_estimate: part2.postsCount,\n  igtv_video_count: part2.igtvVideoCount,\n  highlight_reel_count: part2.highlightReelCount,\n  is_business_account: part2.isBusinessAccount,\n  is_private: part2.private,\n  is_verified: part2.verified,\n  business_category_name: part2.businessCategoryName,\n  external_url: part2.externalUrl,\n  profile_pic_url: part2.profilePicUrlHD || part2.profilePicUrl,\n  facebook_id: part2.fbid\n};\n\n// Extract business address fields explicitly if they exist\nif (part2.businessAddress) {\n  mappedPart2.business_city = part2.businessAddress.city_name;\n  mappedPart2.business_street = part2.businessAddress.street_address;\n  mappedPart2.business_zip = part2.businessAddress.zip_code;\n  mappedPart2.business_latitude = part2.businessAddress.latitude;\n  mappedPart2.business_longitude = part2.businessAddress.longitude;\n}\n\n// Combine everything from part 1 with the extracted fields from part 2\nconst result = {\n  ...part1,\n  ...mappedPart2\n};\n\n// Return the merged object back to n8n\nreturn [{ json: result }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
