      "id": "31a8abf4-2f88-4271-9794-65c57fa75665",
      "name": "Quality filter"
    },
    {
      "parameters": {
        "jsCode": "// Ensure we are working with an array of inputs\nconst waitItems = $items(\"Wait\");\nconst httpItems = $items(\"HTTP Request\");\n\n// Assumes 1-to-1 matching based on the current execution context iteration.\n// If running inside a loop, it pulls the matching index.\nconst index = typeof itemIndex !== 'undefined' ? itemIndex : 0;\n\nconst waitData = waitItems[index]?.json || {};\nconst httpData = httpItems[index]?.json || {};\n\n// 1. Extract raw SerpAPI data elements\nconst organicResults = httpData.organic_results || [];\nconst primaryResult = organicResults[0] || {};\nconst rawSnippet = primaryResult.snippet || \"\";\n\n// 2. Extract and Update Metrics (Followers & Bio) from the Google Search Snippet\nlet followerCount = waitData.follower_count || 0;\nlet bio = \"\";\n\nif (rawSnippet) {\n  // Parse dynamic bio text from the snippet\n  // Example pattern: \"@username: “ Bio text starts here...\"\n  const bioMatch = rawSnippet.match(/@[a-zA-Z0-9_.]+:\\s*“([^”]+)/);\n  bio = bioMatch ? bioMatch[1].trim() : rawSnippet;\n\n  // Update follower count if present in snippet (e.g., \"929K followers\")\n  const followerMatch = rawSnippet.match(/([0-9.]+[KMB]?)\\s*followers/i);\n  if (followerMatch) {\n    let rawNum = followerMatch[1].toUpperCase();\n    if (rawNum.includes('K')) {\n      followerCount = parseFloat(rawNum.replace('K', '')) * 1000;\n    } else if (rawNum.includes('M')) {\n      followerCount = parseFloat(rawNum.replace('M', '')) * 1000000;\n    } else {\n      followerCount = parseFloat(rawNum);\n    }\n  }\n}\n\n// 3. Normalize Handles\nconst rawHandle = waitData.instagram_handle || \"\";\nconst normalizedHandle = rawHandle.toLowerCase().replace(/[^a-z0-9_]/g, \"\");\n\n// 4. Determine Tier Configuration Based on Updated Followers\nlet tier = \"Nano\";\nif (followerCount >= 1000000) tier = \"Mega\";\nelse if (followerCount >= 100000) tier = \"Macro\";\nelse if (followerCount >= 10000) tier = \"Mid-Tier\";\nelse if (followerCount >= 5000) tier = \"Micro\";\n\n// 5. Calculate Qualification Score (Example Logic: Combination of followers & engagement)\nconst engagementRate = waitData.engagement_rate || 0.0;\nconst qualificationScore = Math.min(100, Math.round((followerCount / 10000) * 0.4 + (engagementRate * 100) * 0.6));\n\n// 6. Map Status Flags\nconst emailStatus = waitData.email ? \"Verified\" : \"Missing\";\nconst crmSyncStatus = waitData.duplicate === true ? \"Skipped (Duplicate)\" : \"Pending Sync\";\n\n// Return the newly structured row mapping both data sources seamlessly\nreturn [\n  {\n    json: {\n      // Retain original tracking properties from the data stack\n      ...waitData,\n      follower_count: followerCount, // updated dynamically\n      bio: bio,\n      \n      // Target extraction schemas\n      influencer_id: waitData.id || \"\",\n      normalized_handle: normalizedHandle,\n      tier: tier,\n      qualification_score: qualificationScore,\n      email_status: emailStatus,\n      crm_sync_status: crmSyncStatus,\n      last_updated: new Date().toISOString()\n    }\n  }\n];"
      },
