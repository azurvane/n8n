      "id": "994101b9-41b8-4668-80e5-6b5b7c3466f9",
      "name": "Validate input"
    },
    {
      "parameters": {
        "jsCode": "// 1. Get the global static data storage\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.processedRecords) {\n  staticData.processedRecords = {};\n}\n\n// 2. Get ALL incoming items from the node\nconst items = $input.all();\nconst output = [];\n\n// 3. Loop through every single item in the input array\nfor (const item of items) {\n  const incoming = item.json;\n  \n  // Use instagram_handle for the duplicate check base as requested\n  if (!incoming.instagram_handle) {\n    // If the item doesn't have a handle, pass it through without marking as duplicate\n    output.push({ json: { ...incoming, duplicate: false } });\n    continue;\n  }\n\n  const key = String(incoming.instagram_handle).trim().toLowerCase();\n  let isDuplicate = false;\n  let finalRecord = { ...incoming };\n\n  if (staticData.processedRecords[key] !== undefined) {\n    isDuplicate = true;\n    const existing = staticData.processedRecords[key];\n\n    // Merge: keep existing value unless incoming has a non-empty value\n    // Adjusted fields to match your actual payload keys (e.g., follower_count)\n    const mergeFields = ['name', 'company', 'instagram_handle', 'instagram_url', 'follower_count', 'followers', 'bio', 'niche', 'email'];\n    for (const field of mergeFields) {\n      if ((finalRecord[field] === undefined || finalRecord[field] === '') && existing[field]) {\n        finalRecord[field] = existing[field];\n      }\n    }\n    // Update the static storage with the merged record\n    staticData.processedRecords[key] = finalRecord;\n  } else {\n    // First time seeing this handle, save it to storage\n    staticData.processedRecords[key] = finalRecord;\n  }\n\n  // 4. Push the result into our output array\n  output.push({\n    json: {\n      ...finalRecord,\n      duplicate: isDuplicate\n    }\n  });\n}\n\n// 5. Return all processed items back to n8n\nreturn output;"
      },
