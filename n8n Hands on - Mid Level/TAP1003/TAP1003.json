    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nif (!staticData.processedKeys) {\n  staticData.processedKeys = {};\n}\n\nconst item = $input.item.json;\n\n// Normalize profile_url: trim, lowercase, strip trailing slash\nconst normalizedUrl = String(item.profile_url || '')\n  .trim()\n  .toLowerCase()\n  .replace(/\\/+$/, '');\n\nconst recordKey = normalizedUrl;\nconst isDuplicate = staticData.processedKeys[recordKey] !== undefined;\n\nif (!isDuplicate) {\n  staticData.processedKeys[recordKey] = 'reserved';\n}\n\nreturn [{\n  json: {\n    ...item,\n    normalized_profile_url: normalizedUrl,\n    record_key: recordKey,\n    duplicate: isDuplicate\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
