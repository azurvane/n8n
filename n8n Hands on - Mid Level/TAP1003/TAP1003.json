      "id": "78c69576-6214-4640-b9a3-f5b762ab5228",
      "name": "Quality filter"
    },
    {
      "parameters": {
        "jsCode": "// Handle both shapes: the item itself, or an array-wrapped response\nconst raw = $input.item.json;\nconst data = Array.isArray(raw) ? raw[0] : raw;\n\nconst result = (data.organic_results && data.organic_results[0]) || {};\n\nlet title = result.title || '';\n\n// 1. Remove everything up to and including the first \"- \" (e.g., \"Aditi Sharma - \")\nif (title.includes('- ')) {\n  title = title.split('- ').slice(1).join('- ').trim();\n}\n\n// 2. Remove \" at \" and everything after it (e.g., \" at Commonwealth Bank of ...\")\nif (title.toLowerCase().includes(' at ')) {\n  title = title.split(/\\s+[aA][tT]\\s+/)[0].trim();\n}\n\n// Pull the original candidate fields from the node BEFORE the HTTP Request\n// (the HTTP node's own output won't have these unless you kept them upstream)\nconst source = $('Check duplicate').item.json;\n\nreturn [{\n  json: {\n    run_id: source.run_id,\n    record_key: source.record_key,\n    record_id: source.record_id,\n    name: source.name,\n    company: source.company,\n    profile_url: source.normalized_profile_url,\n    linkedin_title: title,            // cleaned title\n    linkedin_link: result.link || '',\n    linkedin_snippet: result.snippet || '',\n    status: 'success',\n    processed_at: $now.toISO()\n  }\n}];"
      },
