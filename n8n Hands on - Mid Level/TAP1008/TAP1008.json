      "parameters": {
        "jsCode": "// 1. Extract the SMTP dispatch response and the email metadata\nconst emailDispatch = $input.all()[0].json;\nconst emailMetadata = $input.all()[1].json;\n\n// 2. Combine them into a single clean object for tracking/logging\nreturn [{\n  json: {\n    message_id: emailMetadata.message_id,\n    from_lead: emailMetadata.from,\n    original_subject: emailMetadata.subject,\n    ai_reply_subject: emailMetadata.ai_reply_subject,\n    ai_reply_body: emailMetadata.ai_reply_body,\n    status: emailMetadata.status,\n    sent_at: emailMetadata.sent_at,\n    \n    // Append the SMTP system details\n    smtp_message_id: emailDispatch.messageId,\n    smtp_response: emailDispatch.response,\n    accepted_recipients: emailDispatch.accepted,\n    envelope_from: emailDispatch.envelope?.from\n  }\n}];"
