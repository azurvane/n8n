    {
      "parameters": {
        "jsCode": "// 1. Extract the two distinct items from the input array\nconst dedupData = $input.all()[0].json; \nconst rawAiOutput = $input.all()[1]?.json?.output || '';\n\n// 2. Set default fallbacks in case parsing fails\nlet replySubject = `Re: ${dedupData.subject || 'Your Inquiry'}`;\nlet replyBody = rawAiOutput;\n\n// 3. Extract the Subject line and Body from the markdown text\nif (rawAiOutput.includes('**Subject:**')) {\n  // Split the text by lines\n  const lines = rawAiOutput.split('\\n');\n  \n  // Find the subject line and strip out \"**Subject:** \"\n  const subjectLine = lines.find(line => line.toLowerCase().includes('**subject:**'));\n  if (subjectLine) {\n    replySubject = subjectLine.replace(/\\*\\*Subject:\\*\\*\\s*/i, '').trim();\n  }\n  \n  // The rest of the text becomes the body (excluding the subject line)\n  replyBody = lines\n    .filter(line => !line.toLowerCase().includes('**subject:**'))\n    .join('\\n')\n    .trim();\n}\n\n// 4. Return the unified structure for your next step\nreturn [{\n  json: {\n    message_id: dedupData.message_id,\n    from: dedupData.from,\n    subject: dedupData.subject,\n    ai_reply_subject: replySubject,\n    ai_reply_body: replyBody,\n    status: 'sent',\n    sent_at: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
